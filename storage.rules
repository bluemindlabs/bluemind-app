rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Contribution images live under /contributions/{uid}/{fileName}.
    // Anyone can read (images shown on the public community map).
    // Only the authenticated owner can write to their own folder,
    // limited to images under 5 MB.
    match /contributions/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Profile avatars under /avatars/{uid}/...
    match /avatars/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
