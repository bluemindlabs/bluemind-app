# ============================================================
# BlueMind environment variables
# Copy this file to ".env.local" and fill in your own values.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# The GEMINI key has NO prefix, so it stays server-only. Never expose it.
# ============================================================

# --- Firebase (from Firebase Console > Project settings > Your apps > Web app) ---
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abcdef123456

# --- Google Gemini (from https://aistudio.google.com/app/apikey) ---
# SERVER ONLY. Do not add NEXT_PUBLIC_ to this.
GEMINI_API_KEY=your_gemini_api_key

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
